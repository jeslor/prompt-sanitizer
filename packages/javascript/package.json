{
  "name": "prompt-sanitizer",
  "version": "1.0.0",
  "description": "Lightweight, tiered, bidirectional PII sanitizer for LLM pipelines",
  "keywords": [
    "pii",
    "llm",
    "privacy",
    "sanitizer",
    "redaction",
    "openai",
    "langchain"
  ],
  "author": "Jeslor Ssozi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jeslor/prompt-sanitizer.git"
  },
  "homepage": "https://github.com/jeslor/prompt-sanitizer#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./integrations/vercel-ai": {
      "import": "./dist/integrations/vercel-ai.js",
      "require": "./dist/integrations/vercel-ai.cjs",
      "types": "./dist/integrations/vercel-ai.d.ts"
    },
    "./integrations/express": {
      "import": "./dist/integrations/express.js",
      "require": "./dist/integrations/express.cjs",
      "types": "./dist/integrations/express.d.ts"
    },
    "./integrations/nextjs": {
      "import": "./dist/integrations/nextjs.js",
      "require": "./dist/integrations/nextjs.cjs",
      "types": "./dist/integrations/nextjs.d.ts"
    },
    "./integrations/langchain": {
      "import": "./dist/integrations/langchain.js",
      "require": "./dist/integrations/langchain.cjs",
      "types": "./dist/integrations/langchain.d.ts"
    },
    "./integrations/llamaindex": {
      "import": "./dist/integrations/llamaindex.js",
      "require": "./dist/integrations/llamaindex.cjs",
      "types": "./dist/integrations/llamaindex.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests"
  },
  "optionalDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@huggingface/transformers": "^3.0.0"
  },
  "peerDependencies": {
    "@huggingface/transformers": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@huggingface/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.0",
    "@huggingface/transformers": "^4.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
